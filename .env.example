# =============================================================================
# nhain-storefront — biến môi trường
# =============================================================================
# Chép file này thành .env.local để chạy máy mình, và khai báo đúng các biến
# này trong Netlify > Site settings > Environment variables khi deploy.
#
# KHÔNG commit .env hay .env.local lên git. File này chỉ có tên biến, không có
# giá trị thật.
#
# Quy tắc bảo mật quan trọng:
#   * Biến có tiền tố NEXT_PUBLIC_ sẽ ĐI RA TRÌNH DUYỆT. Không bao giờ đặt
#     secret vào đó.
#   * Các biến còn lại chỉ tồn tại trong tiến trình server của website này.
#   * Website KHÔNG cần và KHÔNG được có SUPABASE_SERVICE_ROLE_KEY.
# =============================================================================


# --- Website ----------------------------------------------------------------
# Địa chỉ công khai của website. Dùng cho canonical URL và metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --- Kết nối tới dashboard (BẮT BUỘC) ---------------------------------------
# Địa chỉ gốc của dashboard đang chạy, KHÔNG có dấu / ở cuối.
DASHBOARD_API_URL=https://ten-dashboard-cua-ban.netlify.app

# API key do dashboard cấp (bảng api_clients).
# Cần đủ scope: uploads:create, requests:create
# BÍ MẬT — chỉ ở server. Trình duyệt không bao giờ thấy giá trị này.
DASHBOARD_API_KEY=


# --- Supabase (dùng chung project với dashboard) -----------------------------
# Hai biến này là công khai theo thiết kế của Supabase. An toàn vì RLS chặn:
# anon chỉ đọc được sản phẩm đã publish và cấu hình giao diện.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Bí mật để backend website gọi các RPC storefront_* (đơn hàng, tra cứu).
# Tối thiểu 32 ký tự. Sinh bằng: openssl rand -base64 48
# Sau khi đặt giá trị ở đây, chạy câu INSERT hash được hướng dẫn trong
# HUONG-DAN-TRIEN-KHAI.md. Không dùng storefront_set_secret() trực tiếp trong
# SQL Editor vì SQL Editor không có phiên auth.uid() của super_admin.
STOREFRONT_RPC_SECRET=


# --- Chống bot (Cloudflare Turnstile) ---------------------------------------
# Để trống cả hai thì tính năng tự tắt (tiện khi chạy máy mình).
# Bật ở production: điền cả hai. Thiếu một trong hai coi như chưa bật.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Khóa ký session chống bot. BẮT BUỘC ở production, tối thiểu 32 ký tự.
# Sinh bằng: openssl rand -base64 48
SESSION_SECRET=


# --- Thanh toán chuyển khoản -------------------------------------------------
# Các giá trị này chỉ là DỰ PHÒNG. Admin nhập trong /admin/payment-settings sẽ
# được ưu tiên, và đổi được mà không cần deploy lại.
#
# emv          = tự sinh mã QR ngay trên server (nên dùng: không lộ số tài khoản
#                và số tiền sang bên thứ ba).
# vietqr_image = dùng ảnh dựng sẵn của img.vietqr.io (có logo ngân hàng).
BANK_QR_MODE=vietqr_image

# Mã BIN ngân hàng 6 số. Ví dụ: 970436 = Vietcombank, 970418 = BIDV,
# 970422 = MB Bank, 970407 = Techcombank, 970416 = ACB.
BANK_BIN=
BANK_ACCOUNT_NUMBER=
# Viết KHÔNG DẤU, in hoa — nhiều ngân hàng không nhận dấu tiếng Việt.
BANK_ACCOUNT_NAME=
BANK_NAME=
BANK_BRANCH=
# Tiền tố nội dung chuyển khoản. Kết quả: "NHAIN RFQ 202607 00001".
PAYMENT_PREFIX=NHAIN


# --- Upload ------------------------------------------------------------------
# Hạn dùng của signed upload URL (giây).
SIGNED_URL_EXPIRES_SECONDS=300

# Dung lượng tối đa mỗi file (MB).
# PHẢI <= giới hạn của dashboard, nếu không khách chọn được file rồi mới bị
# dashboard từ chối ở bước cuối.
UPLOAD_MAX_SIZE_MB=25
